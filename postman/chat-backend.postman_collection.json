{
  "info": {
    "_postman_id": "f6a6cb76-5d8f-42df-a338-chat-backend",
    "name": "Chat Backend - Manual Smoke Flow",
    "description": "Sequential manual smoke flow for Wymiana krótkich wiadomości. Run requests from top to bottom. Each request stores IDs and values in environment variables for the next request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Health - reset run variables",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now().toString();",
              "pm.environment.set('runId', runId);",
              "pm.environment.set('adminEmail', `postman-admin-${runId}@example.test`);",
              "pm.environment.set('memberEmail', `postman-member-${runId}@example.test`);",
              "pm.environment.set('secondEmail', `postman-second-${runId}@example.test`);",
              "pm.environment.set('outsiderEmail', `postman-outsider-${runId}@example.test`);",
              "pm.environment.set('messageBody', `postman searchable message ${runId}`);",
              "pm.environment.set('compensationBody', `postman compensated message ${runId}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('service is api-gateway', () => pm.expect(json).to.include({ status: 'ok', service: 'api-gateway' }));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
