              "pm.test('simulated PG failure', () => pm.response.to.have.status(500));",
              "const json = pm.response.json();",
              "pm.test('SIMULATED_PG_FINALIZE_FAILURE code', () => pm.expect(json.code).to.eql('SIMULATED_PG_FINALIZE_FAILURE'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-simulate-pg-finalize-failure",
            "value": "true"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": \"{{adminId}}\",\n  \"body\": \"{{compensationBody}}\",\n  \"attachments\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/conversations/{{groupConversationId}}/messages",
          "host": ["{{baseUrl}}"],
          "path": ["conversations", "{{groupConversationId}}", "messages"]
        }
      }
    },
    {
      "name": "24 Verify compensated message is absent",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('messages listed', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('compensated message deleted from Mongo', () => pm.expect(json.some((m) => m.body === pm.environment.get('compensationBody'))).to.eql(false));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/conversations/{{groupConversationId}}/messages?requesterId={{adminId}}&limit=50",
          "host": ["{{baseUrl}}"],
          "path": ["conversations", "{{groupConversationId}}", "messages"],
          "query": [
            {
              "key": "requesterId",
              "value": "{{adminId}}"
            },
            {
              "key": "limit",
              "value": "50"
            }
          ]
        }
      }
    },
    {
      "name": "25 Soft delete outsider user",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('user soft deleted', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.environment.set('outsiderDeletedAt', json.deletedAt);",
              "pm.test('deletedAt present', () => pm.expect(json.deletedAt).to.be.ok);"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{outsiderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{outsiderId}}"]
        }
      }
    }
  ]
