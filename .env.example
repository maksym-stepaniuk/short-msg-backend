NODE_ENV=development

API_GATEWAY_PORT=3000
PG_SERVICE_PORT=3001
MONGO_SERVICE_PORT=3002
WORKER_SERVICE_PORT=3003
NGINX_PORT=8080
ADMINER_PORT=8081

PG_SERVICE_URL=http://pg-service:3001
MONGO_SERVICE_URL=http://mongo-service:3002
WORKER_SERVICE_URL=http://worker-service:3003
WORKER_REQUEST_TIMEOUT_MS=1000
SERVICE_REQUEST_TIMEOUT_MS=5000

POSTGRES_DB=your_postgres_database
POSTGRES_USER=your_postgres_user
